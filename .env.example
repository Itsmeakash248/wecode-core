# Google Gemini API key (get one free at https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: override Gemini model (default: gemini-1.5-flash)
# GEMINI_MODEL=gemini-1.5-flash

# Backend URL for the Streamlit frontend to call
# Leave as default for local dev; set to your Render backend URL in production
# BIOSYNC_API_URL=https://biosync-backend.onrender.com
